  classDef step fill:#ffffff,stroke:#1f2937,stroke-width:2px,color:#111827,font-weight:600
  classDef data fill:#f3f4f6,stroke:#6b7280,stroke-dasharray: 5 5
  classDef core fill:#dbeafe,stroke:#2563eb
  classDef ai fill:#ede9fe,stroke:#7c3aed
  classDef audit fill:#fee2e2,stroke:#dc2626,stroke-dasharray: 5 5

  class S1,S2,S3,S4,S5,S6,S7,S8 step
  class C1,W1,R1,P1,REP,AUD data
  class S1,S2,S3,S4,S5,S7,S8,BP,ADE,PT core
  class S6,AI,OC,OR ai
  class S8,AUD audit