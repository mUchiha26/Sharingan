# Sharingan Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env with real credentials to version control

# =============================================================================
# AI PROVIDERS (Choose ONE - local or cloud)
# =============================================================================

# Local AI: Ollama (recommended for privacy)
# Ensure Ollama is running: ollama serve
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3.5-9b-unredacted:latest

# Cloud AI: OpenRouter (fallback for complex reasoning)
# Get API key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct

# AI Runtime Settings
AI_TIMEOUT=120                    # Seconds before AI request times out
AI_MAX_TOKENS=2048                # Max tokens in AI response
AI_TEMPERATURE=0.2                # Creativity: 0.0 (deterministic) to 1.0 (creative)

# =============================================================================
# SECURITY & SCOPE (CRITICAL - Define authorized targets)
# =============================================================================

# Comma-separated list of authorized targets (IPs, CIDRs, domains)
# Scans outside this list will be BLOCKED
AUTHORIZED_TARGETS=127.0.0.1,10.0.0.0/24,localhost

# Enable/disable AI analysis (0=disabled, 1=enabled)
# Recommended: Start with 0, enable after testing
SHARINGAN_ENABLE_AI=0

# =============================================================================
# LOGGING & DEBUGGING
# =============================================================================

# Log levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
SHARINGAN_LOG_LEVEL=INFO

# Enable structured JSON logs (for SIEM integration)
SHARINGAN_LOG_JSON=0

# Audit log file path (relative to project root)
SHARINGAN_AUDIT_LOG=data/audit/audit.jsonl

# =============================================================================
# TOOL CONFIGURATION
# =============================================================================

# Nmap settings
NMAP_TIMEOUT=300                  # Max seconds per nmap scan
NMAP_RATE=1000                    # Packets per second (adjust for network)

# Amass settings
AMASS_TIMEOUT=600
AMASS_MAX_DEPTH=3

# Report settings
REPORT_FORMAT=pdf                 # Options: json, pdf, html, markdown
REPORT_OUTPUT_DIR=reports

# =============================================================================
# DOCKER & DEPLOYMENT
# =============================================================================

# Container settings (for docker-compose)
CONTAINER_LOG_LEVEL=INFO
CONTAINER_DATA_VOLUME=./data
CONTAINER_REPORTS_VOLUME=./reports

# =============================================================================
# DEVELOPMENT (Do not use in production)
# =============================================================================

# Skip scope validation (DANGEROUS - for local testing only)
DEV_SKIP_SCOPE_CHECK=0

# Mock AI responses for testing (no API calls)
DEV_MOCK_AI=0

# Verbose dependency checks on startup
DEV_VERBOSE_DEPS=1